generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Users ──

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      String    @default("USER")
  avatar    String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

// ── Projects ──

model Project {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  type         String
  description  String?
  thumbnailUrl String?
  status       String   @default("ACTIVE")
  apiKey       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events Event[]

  @@map("projects")
}

// ── Events ──

model Event {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventName      String
  sessionId      String?
  userIdentifier String?
  page           String?
  value          Float?
  metadata       String   @default("{}")
  createdAt      DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, eventName])
  @@index([createdAt])
  @@map("events")
}

// ── Notifications ──

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  color     String   @default("blue")
  read      Boolean  @default(false)
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}
