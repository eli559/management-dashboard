generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ──

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      String    @default("USER")
  avatar    String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

// ── Projects ──

model Project {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  type         String
  description  String?
  thumbnailUrl String?
  websiteUrl   String?
  techType     String   @default("js")
  status       String   @default("ACTIVE")
  apiKey       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events Event[]
  errors ProjectError[]

  @@map("projects")
}

// ── Events ──

model Event {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventName      String
  sessionId      String?
  userIdentifier String?
  page           String?
  value          Float?
  metadata       String   @default("{}")
  createdAt      DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, eventName])
  @@index([createdAt])
  @@map("events")
}

// ── Notifications ──

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  color     String   @default("blue")
  read      Boolean  @default(false)
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

// ── Project Errors ──

model ProjectError {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message    String
  stack      String?
  page       String?
  severity   String   @default("medium")
  status     String   @default("new")
  sessionId  String?
  userAgent  String?
  deviceType String?
  deviceName String?
  browser    String?
  count      Int      @default(1)
  fingerprint String?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([fingerprint])
  @@map("project_errors")
}
